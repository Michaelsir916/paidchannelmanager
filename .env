# Token from @BotFather
BOT_TOKEN=8805168248:AAEfVFlWnJzbybw93knJ3ucvQ213pdpJ2X8

# Super admins (permanent, full control) - comma-separated
# Only these people can: grant/revoke bot access to others, see ALL groups
# Use the /myid command to find your own ID
ADMIN_IDS=5970917684,8646911343

# View-only users (permanent, optional) - can only see reports for groups
# THEY added the bot to; cannot change anything
VIEWER_IDS=

# Channel where automatic backups are posted every 2 hours (optional).
# Add the bot as an ADMIN of this channel first. Leave empty to disable.
# Get the channel's ID the same way you'd get a group's ID (forward a
# message from the channel to a bot like @RawDataBot).
BACKUP_CHANNEL_ID=-1003739903329

# NOTE: You do NOT need to set a GROUP_CHAT_ID.
# The bot auto-detects every group/channel it is added to, and remembers
# who added it (that person becomes the "owner" and is the only one who can
# manage that group, besides super admins).
#
# Super admins can grant OTHER people time-limited or permanent access to
# use the bot (as full admins) directly from inside the bot itself, using
# the "👥 Manage Users" button - no .env editing needed for that.



